{
  "name": "keyhole",
  "version": "0.2.0",
  "description": "Hand a secret to your AI coding agent through a localhost form — the value reaches a store by reference and never enters the chat context",
  "type": "module",
  "bin": {
    "keyhole": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/cli-entry.ts --target node --outfile dist/cli.js --banner \"#!/usr/bin/env node\" && chmod +x dist/cli.js",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "secret",
    "credential",
    "api-key",
    "keychain",
    "security",
    "localhost",
    "claude"
  ],
  "homepage": "https://github.com/maferland/keyhole",
  "repository": "https://github.com/maferland/keyhole",
  "license": "MIT",
  "author": {
    "name": "Marc-Antoine Ferland",
    "email": "maferland@users.noreply.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
