#!/usr/bin/env python3
"""Entry point. Logic lives in get_secret.py at the repo/plugin root so it can
be imported and tested in-process. This shim just runs it."""
import os
import sys

# realpath (not abspath): when run via a PATH symlink, __file__ is the symlink,
# so we must resolve it to find get_secret.py next to the real bin/ dir.
_root = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, _root)

from get_secret import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
